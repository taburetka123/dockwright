{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit|MultiEdit",
        "hooks": [
          {"type": "command", "command": "python3 ~/.claude/scripts/gardener-write-guard.py", "timeout": 10}
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Write(~/.claude/gardener/**)",
      "Edit(~/.claude/gardener/**)"
    ],
    "deny": [
      "Write(~/.claude/rules/**)",
      "Edit(~/.claude/rules/**)",
      "Write(~/.claude/skills/**)",
      "Edit(~/.claude/skills/**)",
      "Write(~/.claude/agents/**)",
      "Edit(~/.claude/agents/**)",
      "Write(~/.claude/commands/**)",
      "Edit(~/.claude/commands/**)",
      "Write(~/.claude/scripts/**)",
      "Edit(~/.claude/scripts/**)",
      "Write(~/.claude/settings.json)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.local.json)",
      "Edit(~/.claude/settings.local.json)",
      "Write(~/.codex/**)",
      "Edit(~/.codex/**)",
      "Write(~/projects/**)",
      "Edit(~/projects/**)"
    ]
  }
}
